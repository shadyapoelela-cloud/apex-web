{
  "name": "apex/sdk",
  "description": "Official PHP SDK for the APEX Financial Platform API",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.5"
  },
  "autoload": {
    "psr-4": {
      "Apex\\Sdk\\": "src/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload-dev": {
    "psr-4": {
      "Apex\\Sdk\\Tests\\": "tests/"
    }
  }
}
