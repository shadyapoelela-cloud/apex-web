# ═══════════════════════════════════════════════════════════════
# APEX Financial Platform — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── Environment ──────────────────────────────────────────────
# "development" or "production". In production the app REFUSES to start
# without proper JWT_SECRET / ADMIN_SECRET / CORS_ORIGINS values.
ENVIRONMENT=development

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/apex_db
KB_DATABASE_URL=postgresql://user:password@localhost:5432/apex_knowledge

# ─── Authentication ───────────────────────────────────────────
# REQUIRED in production. Must be >=32 chars. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=your-secure-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Admin ────────────────────────────────────────────────────
# REQUIRED in production. Used as X-Admin-Secret header ONLY.
# Query-param transport is refused in production (was leaking into logs).
ADMIN_SECRET=your-admin-secret-here

# ─── CORS (comma-separated origins) ──────────────────────────
# "*" is REJECTED in production. Must be an explicit allowlist.
# Example: https://apex-app.com,https://admin.apex-app.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── AI Services ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# ─── Email Service ────────────────────────────────────────────
# Backend: "console" (dev/logs only), "smtp", or "sendgrid"
EMAIL_BACKEND=console

# SMTP settings (when EMAIL_BACKEND=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@apex-app.com

# SendGrid settings (when EMAIL_BACKEND=sendgrid)
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM=noreply@apex-app.com

# Platform URL used in email links
PLATFORM_URL=https://apex-app.com

# ─── Payment Gateway ─────────────────────────────────────────
# Backend: "mock" (dev/testing), "stripe" (production)
PAYMENT_BACKEND=mock
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYMENT_CURRENCY=SAR

# ─── File Storage ─────────────────────────────────────────────
# Backend: "local" (default, filesystem) or "s3" (AWS S3 / compatible)
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=uploads

# S3 settings (when STORAGE_BACKEND=s3)
S3_BUCKET=apex-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Custom endpoint for S3-compatible services (DigitalOcean Spaces, MinIO, etc.)
S3_ENDPOINT_URL=
