# ═══════════════════════════════════════════════════════════════
# APEX Financial Platform — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── Environment ──────────────────────────────────────────────
# "development" or "production". In production the app REFUSES to start
# without proper JWT_SECRET / ADMIN_SECRET / CORS_ORIGINS values.
ENVIRONMENT=development

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/apex_db
KB_DATABASE_URL=postgresql://user:password@localhost:5432/apex_knowledge

# ─── Authentication ───────────────────────────────────────────
# REQUIRED in production. Must be >=32 chars. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=your-secure-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Admin ────────────────────────────────────────────────────
# REQUIRED in production. Used as X-Admin-Secret header ONLY.
# Query-param transport is refused in production (was leaking into logs).
ADMIN_SECRET=your-admin-secret-here

# ─── CORS (comma-separated origins) ──────────────────────────
# "*" is REJECTED in production. Must be an explicit allowlist.
# Example: https://apex-app.com,https://admin.apex-app.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── AI Services ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# ─── Email Service ────────────────────────────────────────────
# Backend: "console" (dev/logs only), "smtp", or "sendgrid"
EMAIL_BACKEND=console

# SMTP settings (when EMAIL_BACKEND=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@apex-app.com

# SendGrid settings (when EMAIL_BACKEND=sendgrid)
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM=noreply@apex-app.com

# Platform URL used in email links
PLATFORM_URL=https://apex-app.com

# ─── Payment Gateway ─────────────────────────────────────────
# Backend: "mock" (dev/testing), "stripe" (production)
PAYMENT_BACKEND=mock
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYMENT_CURRENCY=SAR

# ─── File Storage ─────────────────────────────────────────────
# Backend: "local" (default, filesystem) or "s3" (AWS S3 / compatible)
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=uploads

# S3 settings (when STORAGE_BACKEND=s3)
S3_BUCKET=apex-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Custom endpoint for S3-compatible services (DigitalOcean Spaces, MinIO, etc.)
S3_ENDPOINT_URL=

# ─── Observability (Sentry + structured logs) ────────────────
# Create a project at https://sentry.io → Flutter/Python SDK → DSN
# SENTRY_DSN is the ONLY secret needed; the rest have safe defaults.
# Code is in app/core/observability.py and is auto-invoked from main.py.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05   # 0.0-1.0 ; 5% of requests traced
SENTRY_RELEASE=                  # git sha or semver, optional
LOG_FORMAT=json                  # json|text ; json recommended in prod
LOG_LEVEL=INFO                   # DEBUG|INFO|WARNING|ERROR

# ─── CSRF protection ─────────────────────────────────────────
# Double-submit-cookie CSRF defense. Off by default so current bearer-
# token API clients continue working. FLIP TO "true" after the frontend
# migrates to HttpOnly cookie sessions (see A4 migration plan).
# Exempt paths: /health, /auth/login, /auth/register, /docs, /ws/*.
CSRF_ENABLED=false

# ─── Multi-tenancy enforcement ───────────────────────────────
# When "true", any route that doesn't opt-in via the TenantContext
# whitelist must produce a tenant_id. Catches missing app-level guards.
TENANT_STRICT=true

# ─── Audit log (SOC 2 / PDPL compliance) ─────────────────────
# Captures every state-changing request with a redacted body preview
# into the audit log for regulatory review. Disable only in isolated
# test environments.
AUDIT_LOG_ENABLED=true

# ─── Database backups (nightly cron) ─────────────────────────
# Runs via Render cron `apex-api-backup` at 03:00 UTC.
# Uploads a gzipped pg_dump to S3 if BACKUP_S3_BUCKET is set; else
# writes to /tmp (ephemeral on Render — testing mode only).
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=us-east-1
BACKUP_RETENTION_DAYS=30
# Uses AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY from the env.
