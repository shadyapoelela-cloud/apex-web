# ═══════════════════════════════════════════════════════════════
# APEX Financial Platform — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/apex_db
KB_DATABASE_URL=postgresql://user:password@localhost:5432/apex_knowledge

# ─── Authentication ───────────────────────────────────────────
JWT_SECRET=your-secure-random-secret-here
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Admin ────────────────────────────────────────────────────
ADMIN_SECRET=your-admin-secret-here

# ─── CORS (comma-separated origins) ──────────────────────────
# Example: https://apex-app.com,https://admin.apex-app.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── AI Services ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# ─── File Storage ─────────────────────────────────────────────
COA_UPLOAD_DIR=/tmp/apex_coa_uploads
UPLOAD_DIR=uploads
